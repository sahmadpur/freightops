# Production deployment env — copy to `.env` next to docker-compose.prod.yml on
# the server and fill in the secrets. Keep out of git.

# Public hostname — must match the Cloudflare/Traefik Host() route.
APP_HOST=freightops.cybercraft.az

# Postgres (used on FIRST init of the data volume).
POSTGRES_USER=freightops
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=freightops

# App + tooling connection to the db container (internal network).
# Password must match POSTGRES_PASSWORD above.
DATABASE_URL=postgres://freightops:CHANGE_ME@freightops-db:5432/freightops

# better-auth secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME

# Object storage (MinIO). Used from Phase 4 (document uploads) on.
S3_ACCESS_KEY=freightops
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=freightops-documents

# Initial admin seeded by scripts/seed-admin.mts (run once after first deploy).
SEED_ADMIN_EMAIL=admin@freightops.cybercraft.az
SEED_ADMIN_PASSWORD=CHANGE_ME
SEED_ADMIN_NAME=Admin

# SMTP. Defaults to the internal Mailpit sink (mail is captured, not delivered).
# Set these to a real MTA to deliver invitations/notifications.
SMTP_HOST=freightops-mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=FreightOps <no-reply@freightops.cybercraft.az>
# SMTP_USER=
# SMTP_PASS=
