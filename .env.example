# Database
DATABASE_URL=postgres://freightops:freightops_dev@localhost:5432/freightops

# Better Auth
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# MinIO (used from Phase 4 on; configured now so compose and app agree)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=freightops
S3_SECRET_KEY=freightops_dev
S3_BUCKET=freightops-documents

# App
APP_BASE_URL=http://localhost:3000

# SMTP (dev: Mailpit). Host is "mailpit" inside Docker, "localhost" when running on the host.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=FreightOps <no-reply@freightops.local>
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
